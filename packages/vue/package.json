{
  "name": "vccs",
  "type": "module",
  "version": "0.2.0",
  "description": "Composable charting components for Vue 3 — an unofficial port of Recharts",
  "author": "rick-hup",
  "license": "MIT",
  "homepage": "https://github.com/rick-hup/vuecharts#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rick-hup/vuecharts"
  },
  "bugs": {
    "url": "https://github.com/rick-hup/vuecharts/issues"
  },
  "keywords": [
    "charts",
    "vue",
    "vue3",
    "recharts",
    "composable",
    "typescript",
    "svg",
    "data-visualization",
    "charting"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/es/index.mjs"
    }
  },
  "module": "./dist/es/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "./LICENSE",
    "./README.md",
    "./dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "bumpp": "bumpp package.json",
    "pub:release": "pnpm publish --access public",
    "size": "size-limit"
  },
  "typings": "./dist/index.d.ts",
  "peerDependencies": {
    "motion-v": ">=2.0.0",
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "@reduxjs/vue-redux": "^1.0.1",
    "@vueuse/core": "^13.1.0",
    "decimal.js-light": "^2.5.1",
    "es-toolkit": "^1.39.3",
    "eventemitter3": "^5.0.1",
    "immer": "^10.1.1",
    "lodash-es": "^4.17.21",
    "victory-vendor": "^37.3.6"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue-jsx": "^5.0.0",
    "@vue/babel-plugin-jsx": "^1.1.1",
    "@vue/runtime-core": "^3.5.13",
    "vue": "^3.5.13"
  },
  "size-limit": [
    {
      "path": "dist/es/index.mjs",
      "limit": "3.4 kb",
      "ignore": [
        "vue",
        "motion-v"
      ]
    }
  ]
}
